public class Example
{
    public static void main(String[] args)
    {
        //Declaration of variables and its assignments

        String firstName="George";
        String middleName="Peter";
        String lastName="Wainaina";
        int age=20;

        //Taking the first charater of each name in upper case and joining them together
        String initials=firstName.substring(0,1)+middleName.substring(0,1)+lastName.substring(0,1);

        //Changes from upper case to lower case and adds age.
        String password=initials.toLowerCase()+age;  

        // Display the final password.
        System.out.println("Your password = "+ password);

    }
}